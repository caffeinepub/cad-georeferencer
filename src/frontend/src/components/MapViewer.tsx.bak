];

type ManualTool = "none" | "move" | "rotate" | "scale";

interface MapViewerProps {
  pickingState: PickingState;
  points: ControlPoint[];
  dxfData: DxfData | null;
  onMapClick: (lat: number, lng: number) => void;
  onUpdateMapPoint: (id: number, lat: number, lng: number) => void;
